[flake8]
max-line-length = 120
max-complexity = 15
exclude =
    .git,
    __pycache__,
    .pytest_cache,
    .hypothesis,
    .mypy_cache,
    build,
    dist,
    *.egg-info,
    .venv,
    venv
ignore =
    E203,
    W503,
    F811,
    E402,
    E501,
    C901,
    W291,
    W292,
    W293
per-file-ignores =
    __init__.py:F401
