[run]
source = APGI-*.py
    falsification_thresholds.py
    main.py
    utils/
    tests/

omit = */tests/*
    */test_*.py
    */__pycache__/*
    */site-packages/*
    */venv/*
    */env/*
    setup.py
    delete_pycache.py
    activate.sh

[report]
exclude_lines = pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod
    raise ImportError
    # Don't complain about missing debug-only code:
    if self.debug:
    # Don't complain if tests don't hit defensive assertion code:
    raise AssertionError
    raise NotImplementedError
